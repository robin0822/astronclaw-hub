{
  "name": "astronclaw-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "oxlint",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "preview": "vite preview",
    "typecheck": "tsc -b",
    "check": "npm run format:check && npm run lint && npm run typecheck && npm run test && npm run build",
    "test": "vitest run",
    "review:install-hooks": "node scripts/install-git-hooks.cjs",
    "review:risk": "node scripts/review-risk-report.cjs",
    "review:risk:staged": "node scripts/review-risk-report.cjs --staged",
    "review:secrets": "node scripts/secret-scan.cjs",
    "review:secrets:staged": "node scripts/secret-scan.cjs --staged",
    "review:commit": "npm run format:check && npm run lint && npm run typecheck && npm run review:risk:staged && npm run review:secrets:staged",
    "review:ci": "npm run format:check && npm run lint && npm run typecheck && npm run test && npm run build && npm run review:risk && npm run review:secrets",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:api": "node scripts/run-api-contract-e2e.cjs",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:mock": "playwright test e2e/login.spec.ts e2e/theme.spec.ts e2e/ui-smoke.spec.ts"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "antd": "^6.4.5",
    "axios": "^1.18.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.0",
    "tailwindcss": "^4.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "jsdom": "^29.1.1",
    "msw": "^2.14.6",
    "oxlint": "^1.69.0",
    "prettier": "^3.9.1",
    "sass": "^1.101.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  }
}
